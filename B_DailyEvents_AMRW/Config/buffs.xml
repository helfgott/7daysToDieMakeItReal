<?xml version="1.0" encoding="UTF-8" ?>
<configs>
<append xpath="/buffs">

    <!-- ================================================================ -->
    <!--  DAILY MOOD SYSTEM                                                -->
    <!--  Each ~game day, a random small blessing or curse is rolled.      -->
    <!--  6 blessings + 6 curses = 12 outcomes, uniform 1/12 cada uno.     -->
    <!--  Cuando un mood expira, dispara el roller de nuevo automaticamente -->
    <!-- ================================================================ -->

    <!-- ROLLER del humor del dia: invisible, dura .1s solo para tirar -->
    <buff name="dailyMoodRoller" hidden="true" remove_on_death="false">
        <stack_type value="ignore"/>
        <duration value=".1"/>
        <effect_group>
            <!-- Reset flags -->
            <triggered_effect trigger="onSelfBuffStart" action="ModifyCVar" cvar="$dmDone" operation="set" value="0"/>

            <!-- Capturar tiradas para 11 slots (slot 12 es garantizado) -->
            <triggered_effect trigger="onSelfBuffStart" action="ModifyCVar" cvar="$dmRoll1"  operation="set" value="1"><requirement name="RandomRoll" seed_type="Random" min_max="0,100" operation="LT" value="8"/></triggered_effect>
            <triggered_effect trigger="onSelfBuffStart" action="ModifyCVar" cvar="$dmRoll2"  operation="set" value="1"><requirement name="RandomRoll" seed_type="Random" min_max="0,100" operation="LT" value="9"/></triggered_effect>
            <triggered_effect trigger="onSelfBuffStart" action="ModifyCVar" cvar="$dmRoll3"  operation="set" value="1"><requirement name="RandomRoll" seed_type="Random" min_max="0,100" operation="LT" value="10"/></triggered_effect>
            <triggered_effect trigger="onSelfBuffStart" action="ModifyCVar" cvar="$dmRoll4"  operation="set" value="1"><requirement name="RandomRoll" seed_type="Random" min_max="0,100" operation="LT" value="11"/></triggered_effect>
            <triggered_effect trigger="onSelfBuffStart" action="ModifyCVar" cvar="$dmRoll5"  operation="set" value="1"><requirement name="RandomRoll" seed_type="Random" min_max="0,100" operation="LT" value="13"/></triggered_effect>
            <triggered_effect trigger="onSelfBuffStart" action="ModifyCVar" cvar="$dmRoll6"  operation="set" value="1"><requirement name="RandomRoll" seed_type="Random" min_max="0,100" operation="LT" value="14"/></triggered_effect>
            <triggered_effect trigger="onSelfBuffStart" action="ModifyCVar" cvar="$dmRoll7"  operation="set" value="1"><requirement name="RandomRoll" seed_type="Random" min_max="0,100" operation="LT" value="17"/></triggered_effect>
            <triggered_effect trigger="onSelfBuffStart" action="ModifyCVar" cvar="$dmRoll8"  operation="set" value="1"><requirement name="RandomRoll" seed_type="Random" min_max="0,100" operation="LT" value="20"/></triggered_effect>
            <triggered_effect trigger="onSelfBuffStart" action="ModifyCVar" cvar="$dmRoll9"  operation="set" value="1"><requirement name="RandomRoll" seed_type="Random" min_max="0,100" operation="LT" value="25"/></triggered_effect>
            <triggered_effect trigger="onSelfBuffStart" action="ModifyCVar" cvar="$dmRoll10" operation="set" value="1"><requirement name="RandomRoll" seed_type="Random" min_max="0,100" operation="LT" value="33"/></triggered_effect>
            <triggered_effect trigger="onSelfBuffStart" action="ModifyCVar" cvar="$dmRoll11" operation="set" value="1"><requirement name="RandomRoll" seed_type="Random" min_max="0,100" operation="LT" value="50"/></triggered_effect>

            <!-- Cascade: aplicar uno solo segun la tirada -->
            <!-- BENDICIONES (1-6) -->
            <triggered_effect trigger="onSelfBuffStart" action="AddBuff" buff="moodLucky" target="self">
                <requirement name="CVarCompare" cvar="$dmRoll1" operation="Equals" value="1"/>
                <requirement name="CVarCompare" cvar="$dmDone" operation="Equals" value="0"/>
            </triggered_effect>
            <triggered_effect trigger="onSelfBuffStart" action="ModifyCVar" cvar="$dmDone" operation="set" value="1">
                <requirement name="CVarCompare" cvar="$dmRoll1" operation="Equals" value="1"/>
                <requirement name="CVarCompare" cvar="$dmDone" operation="Equals" value="0"/>
            </triggered_effect>

            <triggered_effect trigger="onSelfBuffStart" action="AddBuff" buff="moodEnergetic" target="self">
                <requirement name="CVarCompare" cvar="$dmRoll2" operation="Equals" value="1"/>
                <requirement name="CVarCompare" cvar="$dmDone" operation="Equals" value="0"/>
            </triggered_effect>
            <triggered_effect trigger="onSelfBuffStart" action="ModifyCVar" cvar="$dmDone" operation="set" value="1">
                <requirement name="CVarCompare" cvar="$dmRoll2" operation="Equals" value="1"/>
                <requirement name="CVarCompare" cvar="$dmDone" operation="Equals" value="0"/>
            </triggered_effect>

            <triggered_effect trigger="onSelfBuffStart" action="AddBuff" buff="moodFocused" target="self">
                <requirement name="CVarCompare" cvar="$dmRoll3" operation="Equals" value="1"/>
                <requirement name="CVarCompare" cvar="$dmDone" operation="Equals" value="0"/>
            </triggered_effect>
            <triggered_effect trigger="onSelfBuffStart" action="ModifyCVar" cvar="$dmDone" operation="set" value="1">
                <requirement name="CVarCompare" cvar="$dmRoll3" operation="Equals" value="1"/>
                <requirement name="CVarCompare" cvar="$dmDone" operation="Equals" value="0"/>
            </triggered_effect>

            <triggered_effect trigger="onSelfBuffStart" action="AddBuff" buff="moodSatiated" target="self">
                <requirement name="CVarCompare" cvar="$dmRoll4" operation="Equals" value="1"/>
                <requirement name="CVarCompare" cvar="$dmDone" operation="Equals" value="0"/>
            </triggered_effect>
            <triggered_effect trigger="onSelfBuffStart" action="ModifyCVar" cvar="$dmDone" operation="set" value="1">
                <requirement name="CVarCompare" cvar="$dmRoll4" operation="Equals" value="1"/>
                <requirement name="CVarCompare" cvar="$dmDone" operation="Equals" value="0"/>
            </triggered_effect>

            <triggered_effect trigger="onSelfBuffStart" action="AddBuff" buff="moodInspired" target="self">
                <requirement name="CVarCompare" cvar="$dmRoll5" operation="Equals" value="1"/>
                <requirement name="CVarCompare" cvar="$dmDone" operation="Equals" value="0"/>
            </triggered_effect>
            <triggered_effect trigger="onSelfBuffStart" action="ModifyCVar" cvar="$dmDone" operation="set" value="1">
                <requirement name="CVarCompare" cvar="$dmRoll5" operation="Equals" value="1"/>
                <requirement name="CVarCompare" cvar="$dmDone" operation="Equals" value="0"/>
            </triggered_effect>

            <triggered_effect trigger="onSelfBuffStart" action="AddBuff" buff="moodWarmth" target="self">
                <requirement name="CVarCompare" cvar="$dmRoll6" operation="Equals" value="1"/>
                <requirement name="CVarCompare" cvar="$dmDone" operation="Equals" value="0"/>
            </triggered_effect>
            <triggered_effect trigger="onSelfBuffStart" action="ModifyCVar" cvar="$dmDone" operation="set" value="1">
                <requirement name="CVarCompare" cvar="$dmRoll6" operation="Equals" value="1"/>
                <requirement name="CVarCompare" cvar="$dmDone" operation="Equals" value="0"/>
            </triggered_effect>

            <!-- MALDICIONES (7-11) -->
            <triggered_effect trigger="onSelfBuffStart" action="AddBuff" buff="moodUnlucky" target="self">
                <requirement name="CVarCompare" cvar="$dmRoll7" operation="Equals" value="1"/>
                <requirement name="CVarCompare" cvar="$dmDone" operation="Equals" value="0"/>
            </triggered_effect>
            <triggered_effect trigger="onSelfBuffStart" action="ModifyCVar" cvar="$dmDone" operation="set" value="1">
                <requirement name="CVarCompare" cvar="$dmRoll7" operation="Equals" value="1"/>
                <requirement name="CVarCompare" cvar="$dmDone" operation="Equals" value="0"/>
            </triggered_effect>

            <triggered_effect trigger="onSelfBuffStart" action="AddBuff" buff="moodSluggish" target="self">
                <requirement name="CVarCompare" cvar="$dmRoll8" operation="Equals" value="1"/>
                <requirement name="CVarCompare" cvar="$dmDone" operation="Equals" value="0"/>
            </triggered_effect>
            <triggered_effect trigger="onSelfBuffStart" action="ModifyCVar" cvar="$dmDone" operation="set" value="1">
                <requirement name="CVarCompare" cvar="$dmRoll8" operation="Equals" value="1"/>
                <requirement name="CVarCompare" cvar="$dmDone" operation="Equals" value="0"/>
            </triggered_effect>

            <triggered_effect trigger="onSelfBuffStart" action="AddBuff" buff="moodDistracted" target="self">
                <requirement name="CVarCompare" cvar="$dmRoll9" operation="Equals" value="1"/>
                <requirement name="CVarCompare" cvar="$dmDone" operation="Equals" value="0"/>
            </triggered_effect>
            <triggered_effect trigger="onSelfBuffStart" action="ModifyCVar" cvar="$dmDone" operation="set" value="1">
                <requirement name="CVarCompare" cvar="$dmRoll9" operation="Equals" value="1"/>
                <requirement name="CVarCompare" cvar="$dmDone" operation="Equals" value="0"/>
            </triggered_effect>

            <triggered_effect trigger="onSelfBuffStart" action="AddBuff" buff="moodHungry" target="self">
                <requirement name="CVarCompare" cvar="$dmRoll10" operation="Equals" value="1"/>
                <requirement name="CVarCompare" cvar="$dmDone" operation="Equals" value="0"/>
            </triggered_effect>
            <triggered_effect trigger="onSelfBuffStart" action="ModifyCVar" cvar="$dmDone" operation="set" value="1">
                <requirement name="CVarCompare" cvar="$dmRoll10" operation="Equals" value="1"/>
                <requirement name="CVarCompare" cvar="$dmDone" operation="Equals" value="0"/>
            </triggered_effect>

            <triggered_effect trigger="onSelfBuffStart" action="AddBuff" buff="moodGloomy" target="self">
                <requirement name="CVarCompare" cvar="$dmRoll11" operation="Equals" value="1"/>
                <requirement name="CVarCompare" cvar="$dmDone" operation="Equals" value="0"/>
            </triggered_effect>
            <triggered_effect trigger="onSelfBuffStart" action="ModifyCVar" cvar="$dmDone" operation="set" value="1">
                <requirement name="CVarCompare" cvar="$dmRoll11" operation="Equals" value="1"/>
                <requirement name="CVarCompare" cvar="$dmDone" operation="Equals" value="0"/>
            </triggered_effect>

            <!-- Slot 12 garantizado: moodColdBlooded (maldicion termica) -->
            <triggered_effect trigger="onSelfBuffStart" action="AddBuff" buff="moodCold" target="self">
                <requirement name="CVarCompare" cvar="$dmDone" operation="Equals" value="0"/>
            </triggered_effect>
            <triggered_effect trigger="onSelfBuffStart" action="ModifyCVar" cvar="$dmDone" operation="set" value="1">
                <requirement name="CVarCompare" cvar="$dmDone" operation="Equals" value="0"/>
            </triggered_effect>
        </effect_group>
    </buff>

    <!-- ================================================================ -->
    <!--  Cada mood dura ~1 dia in-game (3000s real time =~50min)         -->
    <!--  Cuando expira, dispara dailyMoodRoller para rerolear            -->
    <!-- ================================================================ -->

    <!-- BENDICIONES -->
    <buff name="moodLucky" name_key="moodLuckyName" description_key="moodLuckyDesc" tooltip_key="moodLuckyName" icon="ui_game_symbol_treasure" icon_color="100,220,255" remove_on_death="false">
        <stack_type value="ignore"/><duration value="3000"/>
        <effect_group>
            <passive_effect name="LootDropProb" operation="perc_add" value=".10"/>
            <triggered_effect trigger="onSelfBuffFinish" action="AddBuff" buff="dailyMoodRoller" target="self"/>
        </effect_group>
    </buff>

    <buff name="moodEnergetic" name_key="moodEnergeticName" description_key="moodEnergeticDesc" tooltip_key="moodEnergeticName" icon="ui_game_symbol_run" icon_color="100,220,255" remove_on_death="false">
        <stack_type value="ignore"/><duration value="3000"/>
        <effect_group>
            <passive_effect name="StaminaChangeOT" operation="perc_add" value=".10"/>
            <triggered_effect trigger="onSelfBuffFinish" action="AddBuff" buff="dailyMoodRoller" target="self"/>
        </effect_group>
    </buff>

    <buff name="moodFocused" name_key="moodFocusedName" description_key="moodFocusedDesc" tooltip_key="moodFocusedName" icon="ui_game_symbol_lightbulb" icon_color="100,220,255" remove_on_death="false">
        <stack_type value="ignore"/><duration value="3000"/>
        <effect_group>
            <passive_effect name="ExperienceGain" operation="perc_add" value=".10"/>
            <triggered_effect trigger="onSelfBuffFinish" action="AddBuff" buff="dailyMoodRoller" target="self"/>
        </effect_group>
    </buff>

    <buff name="moodSatiated" name_key="moodSatiatedName" description_key="moodSatiatedDesc" tooltip_key="moodSatiatedName" icon="ui_game_symbol_stomach" icon_color="100,220,255" remove_on_death="false">
        <stack_type value="ignore"/><duration value="3000"/>
        <effect_group>
            <passive_effect name="FoodMax" operation="perc_add" value=".10"/>
            <triggered_effect trigger="onSelfBuffFinish" action="AddBuff" buff="dailyMoodRoller" target="self"/>
        </effect_group>
    </buff>

    <buff name="moodInspired" name_key="moodInspiredName" description_key="moodInspiredDesc" tooltip_key="moodInspiredName" icon="ui_game_symbol_hammer" icon_color="100,220,255" remove_on_death="false">
        <stack_type value="ignore"/><duration value="3000"/>
        <effect_group>
            <passive_effect name="CraftingTier" operation="perc_add" value=".10"/>
            <triggered_effect trigger="onSelfBuffFinish" action="AddBuff" buff="dailyMoodRoller" target="self"/>
        </effect_group>
    </buff>

    <buff name="moodWarmth" name_key="moodWarmthName" description_key="moodWarmthDesc" tooltip_key="moodWarmthName" icon="ui_game_symbol_hot" icon_color="100,220,255" remove_on_death="false">
        <stack_type value="ignore"/><duration value="3000"/>
        <effect_group>
            <passive_effect name="HypothermalResist" operation="base_add" value="10"/>
            <passive_effect name="HyperthermalResist" operation="base_add" value="10"/>
            <triggered_effect trigger="onSelfBuffFinish" action="AddBuff" buff="dailyMoodRoller" target="self"/>
        </effect_group>
    </buff>

    <!-- MALDICIONES -->
    <buff name="moodUnlucky" name_key="moodUnluckyName" description_key="moodUnluckyDesc" tooltip_key="moodUnluckyName" icon="ui_game_symbol_treasure" icon_color="200,100,100" remove_on_death="false">
        <stack_type value="ignore"/><duration value="3000"/>
        <effect_group>
            <passive_effect name="LootDropProb" operation="perc_add" value="-.10"/>
            <triggered_effect trigger="onSelfBuffFinish" action="AddBuff" buff="dailyMoodRoller" target="self"/>
        </effect_group>
    </buff>

    <buff name="moodSluggish" name_key="moodSluggishName" description_key="moodSluggishDesc" tooltip_key="moodSluggishName" icon="ui_game_symbol_fatigued" icon_color="200,100,100" remove_on_death="false">
        <stack_type value="ignore"/><duration value="3000"/>
        <effect_group>
            <passive_effect name="RunSpeed" operation="perc_add" value="-.05"/>
            <triggered_effect trigger="onSelfBuffFinish" action="AddBuff" buff="dailyMoodRoller" target="self"/>
        </effect_group>
    </buff>

    <buff name="moodDistracted" name_key="moodDistractedName" description_key="moodDistractedDesc" tooltip_key="moodDistractedName" icon="ui_game_symbol_bookworm" icon_color="200,100,100" remove_on_death="false">
        <stack_type value="ignore"/><duration value="3000"/>
        <effect_group>
            <passive_effect name="ExperienceGain" operation="perc_add" value="-.10"/>
            <triggered_effect trigger="onSelfBuffFinish" action="AddBuff" buff="dailyMoodRoller" target="self"/>
        </effect_group>
    </buff>

    <buff name="moodHungry" name_key="moodHungryName" description_key="moodHungryDesc" tooltip_key="moodHungryName" icon="ui_game_symbol_hunger" icon_color="200,100,100" remove_on_death="false">
        <stack_type value="ignore"/><duration value="3000"/>
        <effect_group>
            <passive_effect name="FoodMax" operation="perc_add" value="-.10"/>
            <triggered_effect trigger="onSelfBuffFinish" action="AddBuff" buff="dailyMoodRoller" target="self"/>
        </effect_group>
    </buff>

    <buff name="moodGloomy" name_key="moodGloomyName" description_key="moodGloomyDesc" tooltip_key="moodGloomyName" icon="ui_game_symbol_concussion" icon_color="200,100,100" remove_on_death="false">
        <stack_type value="ignore"/><duration value="3000"/>
        <effect_group>
            <passive_effect name="StaminaChangeOT" operation="perc_add" value="-.10"/>
            <triggered_effect trigger="onSelfBuffFinish" action="AddBuff" buff="dailyMoodRoller" target="self"/>
        </effect_group>
    </buff>

    <buff name="moodCold" name_key="moodColdName" description_key="moodColdDesc" tooltip_key="moodColdName" icon="ui_game_symbol_cold" icon_color="200,100,100" remove_on_death="false">
        <stack_type value="ignore"/><duration value="3000"/>
        <effect_group>
            <passive_effect name="HypothermalResist" operation="base_add" value="-10"/>
            <triggered_effect trigger="onSelfBuffFinish" action="AddBuff" buff="dailyMoodRoller" target="self"/>
        </effect_group