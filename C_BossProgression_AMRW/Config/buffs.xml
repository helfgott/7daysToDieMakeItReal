<?xml version="1.0" encoding="UTF-8" ?>
<configs>
<append xpath="/buffs">

    <!-- ================================================================ -->
    <!--  KILLED MARKER BUFFS                                              -->
    <!--  Cada quest dispara un GameEvent que aplica uno de estos buffs.   -->
    <!--  El buff setea su CVar correspondiente y se autoremueve.          -->
    <!-- ================================================================ -->

    <buff name="bpForestKilled" hidden="true" remove_on_death="false">
        <stack_type value="ignore"/>
        <duration value=".5"/>
        <effect_group>
            <triggered_effect trigger="onSelfBuffStart" action="ModifyCVar" cvar="$bpForestKilled" operation="set" value="1"/>
            <triggered_effect trigger="onSelfBuffStart" action="ModifyCVar" cvar="$bpForestSpawned" operation="set" value="0"/>
        </effect_group>
    </buff>

    <buff name="bpDesertKilled" hidden="true" remove_on_death="false">
        <stack_type value="ignore"/>
        <duration value=".5"/>
        <effect_group>
            <triggered_effect trigger="onSelfBuffStart" action="ModifyCVar" cvar="$bpDesertKilled" operation="set" value="1"/>
            <triggered_effect trigger="onSelfBuffStart" action="ModifyCVar" cvar="$bpDesertSpawned" operation="set" value="0"/>
        </effect_group>
    </buff>

    <buff name="bpSnowKilled" hidden="true" remove_on_death="false">
        <stack_type value="ignore"/>
        <duration value=".5"/>
        <effect_group>
            <triggered_effect trigger="onSelfBuffStart" action="ModifyCVar" cvar="$bpSnowKilled" operation="set" value="1"/>
            <triggered_effect trigger="onSelfBuffStart" action="ModifyCVar" cvar="$bpSnowSpawned" operation="set" value="0"/>
        </effect_group>
    </buff>

    <buff name="bpBurntKilled" hidden="true" remove_on_death="false">
        <stack_type value="ignore"/>
        <duration value=".5"/>
        <effect_group>
            <triggered_effect trigger="onSelfBuffStart" action="ModifyCVar" cvar="$bpBurntKilled" operation="set" value="1"/>
            <triggered_effect trigger="onSelfBuffStart" action="ModifyCVar" cvar="$bpBurntSpawned" operation="set" value="0"/>
        </effect_group>
    </buff>

    <buff name="bpWastelandKilled" hidden="true" remove_on_death="false">
        <stack_type value="ignore"/>
        <duration value=".5"/>
        <effect_group>
            <triggered_effect trigger="onSelfBuffStart" action="ModifyCVar" cvar="$bpWastelandKilled" operation="set" value="1"/>
            <triggered_effect trigger="onSelfBuffStart" action="ModifyCVar" cvar="$bpWastelandSpawned" operation="set" value="0"/>
        </effect_group>
    </buff>

    <buff name="bpFinalKilled" hidden="false" remove_on_death="false"
          name_key="bpFinalKilledName" description_key="bpFinalKilledDesc"
          icon="ui_game_symbol_skull" icon_color="220,40,40">
        <stack_type value="ignore"/>
        <duration value="0"/>
        <effect_group>
            <triggered_effect trigger="onSelfBuffStart" action="ModifyCVar" cvar="$bpFinalKilled" operation="set" value="1"/>
            <triggered_effect trigger="onSelfBuffStart" action="ModifyCVar" cvar="$bpFinalSpawned" operation="set" value="0"/>
            <!-- Disparar el countdown del endgame al matar al final boss -->
            <triggered_effect trigger="onSelfBuffStart" action="AddBuff" buff="bpEndgameWarning" target="self">
                <requirement name="CVarCompare" cvar="$bpEndgameStarted" operation="Equals" value="0"/>
            </triggered_effect>
            <triggered_effect trigger="onSelfBuffStart" action="ModifyCVar" cvar="$bpEndgameStarted" operation="set" value="1">
                <requirement name="CVarCompare" cvar="$bpEndgameStarted" operation="Equals" value="0"/>
            </triggered_effect>
        </effect_group>
    </buff>


    <!-- ================================================================ -->
    <!--  ENDGAME COUNTDOWN                                                -->
    <!--  Visible. 1800s (30 min reales) de cuenta atras.                  -->
    <!--  Al expirar dispara bpEndgameHordeActive permanentemente.         -->
    <!-- ================================================================ -->

    <buff name="bpEndgameWarning" hidden="false" remove_on_death="false"
          name_key="bpEndgameWarningName" description_key="bpEndgameWarningDesc"
          icon="ui_game_symbol_skull" icon_color="255,140,0">
        <stack_type value="ignore"/>
        <duration value="1800"/>
        <effect_group>
            <triggered_effect trigger="onSelfBuffStart" action="ShowToolbeltMessage" message_key="bpEndgameWarning_start_msg"/>
            <triggered_effect trigger="onSelfBuffFinish" action="AddBuff" buff="bpEndgameHordeActive" target="self"/>
        </effect_group>
    </buff>


    <!-- ================================================================ -->
    <!--  ENDGAME HORDE ACTIVE                                             -->
    <!--  Permanente. Cada 300s dispara una oleada via GameEvent.          -->
    <!-- ================================================================ -->

    <buff name="bpEndgameHordeActive" hidden="false" remove_on_death="false"
          name_key="bpEndgameHordeActiveName" description_key="bpEndgameHordeActiveDesc"
          icon="ui_game_symbol_skull" icon_color="255,0,0" icon_blink="true">
        <stack_type value="ignore"/>
        <duration value="0"/>
        <update_rate value="300"/>
        <effect_group>
            <triggered_effect trigger="onSelfBuffStart" action="ShowToolbeltMessage" message_key="bpEndgameHorde_start_msg"/>
            <triggered_effect trigger="onSelfBuffUpdate" action="CallGameEvent" event="eventBpEndgameWave"/>
        </effect_group>
    </buff>


    <!-- ================================================================ -->
    <!--  TRACKER BUFF                                                     -->
    <!--  Permanente y oculto. En cada update revisa cuales quests deberia -->
    <!--  ofrecer el jugador, segun el progreso. Se aplica automaticamente -->
    <!--  al spawnear (via entityclasses hook).                            -->
    <!-- ================================================================ -->

    <buff name="bpProgressionTracker" hidden="true" remove_on_death="false">
        <stack_type value="ignore"/>
        <duration value="0"/>
        <update_rate value="30"/>
        <effect_group>
            <!-- Marcar como activo -->
            <triggered_effect trigger="onSelfBuffStart" action="ModifyCVar" cvar="$bpTrackerActive" operation="set" value="1"/>

            <!-- Cuando los 5 campeones esten muertos y aun no se ofrecio la quest final,
                 llamar al gameevent que agrega la quest final. -->
            <triggered_effect trigger="onSelfBuffUpdate" action="CallGameEvent" event="eventBpGiveFinalQuest">
                <requirement name="CVarCompare" cvar="$bpForestKilled" operation="Equals" value="1"/>
                <requirement name="CVarCompare" cvar="$bpDesertKilled" operation="Equals" value="1"/>
                <requirement name="CVarCompare" cvar="$bpSnowKilled" operation="Equals" value="1"/>
                <requirement name="CVarCompare" cvar="$bpBurntKilled" operation="Equals" value="1"/>
                <requirement name="CVarCompare" cvar="$bpWastelandKilled" operation="Equals" value="1"/>
                <requirement name="CVarCompare" cvar="$bpFinalOffered" operation="Equals" value="0"/>
            </triggered_effect>
            <triggered_effect trigger="onSelfBuffUpdate" action="ModifyCVar" cvar="$bpFinalOffered" operation="set" value="1">
                <requirement name="CVarCompare" cvar="$bpForestKilled" operation="Equals" value="1"/>
                <requirement name="CVarCompare" cvar="$bpDesertKilled" operation="Equals" value="1"/>
                <requirement name="CVarCompare" cvar="$bpSnowKilled" operation="Equals" value="1"/>
       