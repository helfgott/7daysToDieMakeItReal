            <property name="text" value="| [602020]BURNT CHAMPION:[-] Siren Head emerges from the ashes."/>
            <property name="text_key" value="eventBpBurntArrival_msg"/>
        </action>
        <action class="SpawnEntity">
            <property name="safe_spawn" value="true"/>
