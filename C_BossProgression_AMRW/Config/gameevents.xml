<?xml version="1.0" encoding="UTF-8" ?>
<configs>
<append xpath="/gameevents">

    <!-- ================================================================ -->
    <!--  BIOME CHAMPION SPAWN EVENTS                                      -->
    <!--  Each one spawns its boss once, near the player.                  -->
    <!--  Used by quests as the "boss arrival" step.                       -->
    <!-- ================================================================ -->

    <action_sequence name="eventBpForestChampionArrival">
        <action class="AddChatMessage">
            <property name="text" value="| [00CC00]FOREST CHAMPION:[-] The Druid has emerged from the woods. Hunt it down."/>
            <property name="text_key" value="eventBpForestArrival_msg"/>
        </action>
        <action class="SpawnEntity">
            <property name="safe_spawn" value="true"/>
            <property name="entity_names" value="AECTheDruidBoss"/>
            <property name="spawn_count" value="1"/>
            <property name="min_distance" value="15"/>
            <property name="max_distance" value="30"/>
            <property name="spawn_type" value="Position"/>
            <property name="is_aggressive" value="true"/>
        </action>
        <action class="ModifyCVar">
            <property name="cvar" value="$bpForestSpawned"/>
            <property name="operation" value="set"/>
            <property name="value" value="1"/>
        </action>
    </action_sequence>

    <action_sequence name="eventBpDesertChampionArrival">
        <action class="AddChatMessage">
            <property name="text" value="| [E0A030]DESERT CHAMPION:[-] Mykir rises from the sands."/>
