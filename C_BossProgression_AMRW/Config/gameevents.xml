    <!-- ================================================================ -->
    <!--  KILL MARKER EVENTS                                               -->
    <!--  Quests on_complete dispara estos. Aplican el buff marcador       -->
    <!--  que setea la CVar correspondiente.                               -->
    <!-- ================================================================ -->

    <action_sequence name="eventBpMarkForestKilled">
        <action class="AddEntitiesToGroup">
            <property name="entity_tags" value="player"/>
            <property name="group_name" value="bpNearbyPlayers"/>
            <property name="exclude_target" value="false"/>
            <property name="max_distance" value="50"/>
        </action>
        <action class="AddChatMessage">
            <property name="text" value="| [00CC00]Forest Champion defeated.[-] (1/5)"/>
            <property name="target_group" value="bpNearbyPlayers"/>
        </action>
        <action class="AddBuff">
            <property name="buff_name" value="bpForestKilled"/>
            <property name="target_group" value="bpNearbyPlayers"/>
        </action>
    </action_sequence>

