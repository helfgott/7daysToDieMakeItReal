<?xml version="1.0" encoding="UTF-8" ?>
<configs>
<append xpath="/quests">

    <!--
        BIOME CHAMPION QUESTS (5)
        - One-time quests (repeatable=false)
        - Auto-completed when boss is killed
        - On complete: trigger event that sets killed CVar
        - Quest sends player to specific biome POI, then spawns boss there

        FINAL BOSS QUEST (1)
        - Prerequisites: all 5 champion quests completed
        - Killing the Executioner sets $bpFinalKilled = 1
    -->

    <!-- ===== FOREST CHAMPION: The Druid ===== -->
    <quest id="questBpForestChampion">
        <property name="name_key" value="questBpForestChampion_name"/>
        <property name="subtitle_key" value="questBpForestChampion_subtitle"/>
        <property name="description_key" value="questBpForestChampion_description"/>
        <property name="icon" value="ui_game_symbol_skull"/>
        <property name="repeatable" value="false"/>
        <property name="category_key" value="quest"/>
        <property name="difficulty_tier" value="5"/>
        <property name="offer_key" value="questBpForestChampion_offer"/>
        <property name="statement_key" value="questBpForestChampion_statement"/>
        <property name="response_key" value="questBpForestChampion_response"/>
        <property name="completiontype" value="AutoComplete"/>
        <property name="completion_key" value="questBpForestChampion_completion"/>

        <objective type="EntityKill"><property name="objective_name_key" value="questBpForestChampion_obj_kill"/><property name="needed_count" value="1"/><property name="target_entity_class" value="AECTheDruidBoss"/><property name="nav_object" value="bpForestMarker"/><property name="phase" value="1"/></objective>

        <reward type="Exp" value="50000"/>
        <action type="GameEvent" id="eventBpMarkForestKilled"><property name="on_complete" value="true"/></action>
    </quest>

