<?xml version="1.0" encoding="UTF-8" ?>
<configs>

    <append xpath="/entity_classes/entity_class[@name='playerMale']">
        <effect_group name="MakeItRealisticHookMale">
            <triggered_effect trigger="onSelfEnteredGame" action="AddBuff" buff="realisticTraitRoller" target="self">
                <requirement name="CVarCompare" cvar="$rtRolled" operation="Equals" value="0"/>
            </triggered_effect>
            <triggered_effect trigger="onSelfEnteredGame" action="AddBuff" buff="dailyMoodRoller" target="self">
                <requirement name="!HasBuff" buff="moodLucky"/>
                <requirement name="!HasBuff" buff="moodEnergetic"/>
                <requirement name="!HasBuff" buff="moodFocused"/>
                <requirement name="!HasBuff" buff="moodSatiated"/>
                <requirement name="!HasBuff" buff="moodInspired"/>
                <requirement name="!HasBuff" buff="moodWarmth"/>
                <requirement name="!HasBuff" buff="moodUnlucky"/>
                <requirement name="!HasBuff" buff="moodSluggish"/>
                <requirement name="!HasBuff" buff="moodDistracted"/>
                <requirement name="!HasBuff" buff="moodHungry"/>
                <requirement name="!HasBuff" buff="moodGloomy"/>
                <requirement name="!HasBuff" buff="moodCold"/>
            </triggered_effect>
        </effect_group>
    </append>

    <append xpath="/entity_classes/entity_class[@name='playerFemale']">
        <effect_group name="MakeItRealisticHookFemale">
            <triggered_effect trigger="onSelfEnteredGame" action="AddBuff" buff="realisticTraitRoller" target="self">
                <requirement name="CVarCompare" cvar="$rtRolled" operation="Equals" value="0"/>
            </triggered_effect>
            <triggered_effect trigger="onSelfEnteredGame" action="AddBuff" buff="dailyMoodRoller" target="self">
                <requirement name="!HasBuff" buff="moodLucky"/>
                <requirement name="!HasBuff" buff="moodEnergetic"/>
                <requirement name="!HasBuff" buff="moodFocused"/>
                <requirement name="!HasBuff" buff="moodSatiated"/>
                <requirement name="!HasBuff" buff="moodInspired"/>
                <requirement name="!HasBuff" buff="moodWarmth"/>
                <requirement name="!HasBuff" buff="moodUnlucky"/>
                <requirement name="!HasBuff" buff="moodSluggish"/>
                <requirement name="!HasBuff" buff="moodDistracted"/>
                <requirement name="!HasBuff" buff="moodHungry"/>
                <requirement name="!HasBuff" buff="moodGloomy"/>
                <requirement name="!HasBuff" buff="moodCold"/>
            </triggered_effect>
        </effect_group>
    </append>

</configs>
